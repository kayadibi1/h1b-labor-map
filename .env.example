BLS_API_KEY=

# Optional: ProPublica Nonprofit Explorer (no key required at time of writing, but
# rate-limited. If you have a contact email, set it for polite User-Agent.)
PROPUBLICA_CONTACT_EMAIL=

# Optional: Lightcast Open Data (if you have access)
LIGHTCAST_API_KEY=
